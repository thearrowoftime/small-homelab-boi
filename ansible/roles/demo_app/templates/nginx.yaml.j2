# {{ ansible_managed }}
apiVersion: v1
kind: Namespace
metadata:
  name: {{ demo_app_namespace }}
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: nginx-index
  namespace: {{ demo_app_namespace }}
data:
  index.html: |
    <!doctype html>
    <html lang="en">
    <head>
      <meta charset="utf-8">
      <title>Home Lab - Ansible + k3s</title>
      <style>
        :root { color-scheme: dark; }
        body { font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
               background: #0b1020; color: #e6e9f2; margin: 0;
               min-height: 100vh; display: grid; place-items: center; }
        .card { padding: 2.5rem 3rem; border: 1px solid #2a3258;
                border-radius: 14px; background: #11173a;
                box-shadow: 0 10px 40px rgba(0,0,0,.4); max-width: 640px; }
        h1 { margin: 0 0 .5rem; font-size: 1.7rem; }
        .tag { display: inline-block; padding: 2px 10px; border-radius: 999px;
               background: #1f2a5b; color: #9bb5ff; font-size: .8rem;
               margin-right: .25rem; }
        code { background: #0a0f29; padding: 1px 6px; border-radius: 4px; }
        ul { line-height: 1.7; }
        a { color: #7aa2ff; }
      </style>
    </head>
    <body>
      <div class="card">
        <h1>It works.</h1>
        <p>
          <span class="tag">Ansible</span>
          <span class="tag">k3s</span>
          <span class="tag">Helm</span>
          <span class="tag">Prometheus</span>
          <span class="tag">Grafana</span>
        </p>
        <p>This page is served by <code>nginx</code> running on a 3-node k3s cluster,
        deployed end-to-end by Ansible.</p>
        <ul>
          <li>Demo app - this page (NodePort {{ demo_app_nodeport }})</li>
          <li>Prometheus - <a href="http://localhost:{{ prometheus_nodeport }}">localhost:{{ prometheus_nodeport }}</a></li>
          <li>Grafana - <a href="http://localhost:{{ grafana_nodeport }}">localhost:{{ grafana_nodeport }}</a></li>
        </ul>
        <p>Pod: <code id="host"></code></p>
        <script>document.getElementById("host").textContent = window.location.hostname + " / " + (new Date()).toISOString();</script>
      </div>
    </body>
    </html>
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: nginx-demo
  namespace: {{ demo_app_namespace }}
  labels:
    app: nginx-demo
spec:
  replicas: {{ demo_app_replicas }}
  selector:
    matchLabels:
      app: nginx-demo
  template:
    metadata:
      labels:
        app: nginx-demo
    spec:
      containers:
        - name: nginx
          image: {{ demo_app_image }}
          ports:
            - containerPort: 80
              name: http
          volumeMounts:
            - name: index
              mountPath: /usr/share/nginx/html
          resources:
            requests:
              cpu: 25m
              memory: 32Mi
            limits:
              cpu: 200m
              memory: 128Mi
          readinessProbe:
            httpGet: { path: /, port: http }
            initialDelaySeconds: 2
          livenessProbe:
            httpGet: { path: /, port: http }
            initialDelaySeconds: 5
      volumes:
        - name: index
          configMap:
            name: nginx-index
---
apiVersion: v1
kind: Service
metadata:
  name: nginx-demo
  namespace: {{ demo_app_namespace }}
  labels:
    app: nginx-demo
spec:
  type: NodePort
  selector:
    app: nginx-demo
  ports:
    - name: http
      port: 80
      targetPort: 80
      nodePort: {{ demo_app_nodeport }}
